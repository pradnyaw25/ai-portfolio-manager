# LLM Provider
OPENAI_API_KEY=your-openai-api-key
# LLM_PROVIDER=openai
# Per-tier routing: strong = final decisions / PM synthesis / judges;
# cheap = analysts, summaries, tweets. Set strong to a pricier model (e.g. gpt-4o)
# to make the cheap/strong split save cost.
# LLM_STRONG_PROVIDER=openai
# LLM_STRONG_MODEL=gpt-4o-mini
# LLM_CHEAP_PROVIDER=openai
# LLM_CHEAP_MODEL=gpt-4o-mini
# Optional fallback route, tried if the primary provider fails after retries.
# LLM_FALLBACK_PROVIDER=openai
# LLM_FALLBACK_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=1.0
# LLM_MAX_RETRIES=2

# Memory / Vector Store
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key
# QDRANT_COLLECTION=fund_memory

# Observability (optional — tracing is a no-op unless both keys are set)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# SEC EDGAR
# Use an app/contact identifier for SEC automated access.
SEC_USER_AGENT=AI Portfolio Manager your-email@example.com

# News. The fund uses the keyless, real-time Google News RSS feed by default.
# NEWS_API_KEY (optional) enables NewsAPI.org as a fallback when RSS returns nothing.
# The free NewsAPI tier has a ~24h delay + 100 req/day cap, so RSS is preferred;
# set PREFER_NEWSAPI=true to use NewsAPI first (recommended only on a paid plan).
# NEWS_API_KEY=your-newsapi-key
# PREFER_NEWSAPI=false

# X / Twitter Publishing
POST_TWEET=false
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# Portfolio Settings
INITIAL_CAPITAL=1000000
MAX_POSITION_SIZE=0.10

# Risk Engine V2
# Max fraction of the portfolio in any one GICS sector (config/sectors.yaml).
MAX_SECTOR_CONCENTRATION=0.40
# Auto-exit a position once it falls/rises this fraction from cost basis.
STOP_LOSS_PCT=0.15
TAKE_PROFIT_PCT=0.40

# Weekly investor letter — set true to also post it as an X thread (off by default).
POST_INVESTOR_LETTER=false

# Trades execute only during regular US market hours (9:30-16:00 America/New_York);
# outside them, the cycle still runs but execution is skipped. Set true to override
# for testing/backfill.
# EXECUTE_OUTSIDE_MARKET_HOURS=false

# Human-in-the-loop approval
# Leave true for unattended/scheduled runs. Set false to pause each run after
# risk review and be prompted in-terminal to approve/reject/edit trades.
AUTO_APPROVE=true

# Bull/bear/risk debate before the PM decides. Set false to ablate the committee
# (the PM decides directly) — used to measure debate vs no-debate.
ENABLE_DEBATE=true

# Logging
LOG_LEVEL=INFO
