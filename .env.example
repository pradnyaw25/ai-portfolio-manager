# LLM Provider
OPENAI_API_KEY=your-openai-api-key
# LLM_PROVIDER=openai
# Per-tier routing: strong = final decisions / PM synthesis / judges;
# cheap = analysts, summaries, tweets. Set strong to a pricier model (e.g. gpt-4o)
# to make the cheap/strong split save cost.
# LLM_STRONG_PROVIDER=openai
# LLM_STRONG_MODEL=gpt-4o-mini
# LLM_CHEAP_PROVIDER=openai
# LLM_CHEAP_MODEL=gpt-4o-mini
# Optional fallback route, tried if the primary provider fails after retries.
# LLM_FALLBACK_PROVIDER=openai
# LLM_FALLBACK_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=1.0
# LLM_MAX_RETRIES=2

# Memory / Vector Store
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key
# QDRANT_COLLECTION=fund_memory

# Observability (optional — tracing is a no-op unless both keys are set)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# SEC EDGAR
# Use an app/contact identifier for SEC automated access.
SEC_USER_AGENT=AI Portfolio Manager your-email@example.com

# X / Twitter Publishing
POST_TWEET=false
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# Portfolio Settings
INITIAL_CAPITAL=1000000
MAX_POSITION_SIZE=0.10

# Human-in-the-loop approval
# Leave true for unattended/scheduled runs. Set false to pause each run after
# risk review and be prompted in-terminal to approve/reject/edit trades.
AUTO_APPROVE=true

# Logging
LOG_LEVEL=INFO
